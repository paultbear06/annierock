<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Annie Rock Studios | Control Center</title>
    <style>
        body {
            background-color: #121212;
            color: #f4f4f4;
            font-family: -apple-system, BlinkMacSystemFont, sans-serif;
            padding: 20px;
            margin: 0;
        }
        .container { max-width: 800px; margin: 40px auto; padding: 20px; background: #1e1e1e; border-radius: 8px; border: 1px solid #2a2a2a; }
        h1 { color: #e07a5f; text-align: center; }
        .hidden { display: none !important; }
        .form-group { margin-bottom: 20px; }
        label { display: block; margin-bottom: 8px; font-weight: bold; color: #a0a0a0; }
        input[type="password"], textarea, select {
            width: 100%; padding: 12px; border-radius: 4px; border: 1px solid #333; background: #121212; color: #f4f4f4; box-sizing: border-box;
        }
        textarea { height: 180px; font-family: monospace; }
        .btn {
            background: #e07a5f; color: #121212; padding: 12px 24px; border: none; border-radius: 4px; font-weight: bold; cursor: pointer; width: 100%; margin-top: 10px;
        }
        .btn:hover { background: #f29075; }
        .box-selector { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 20px; }
        .box-option {
            background: #252525; border: 2px solid #333; padding: 20px; border-radius: 6px; text-align: center; cursor: pointer;
        }
        .box-option.active { border-color: #e07a5f; background: #2d2421; }
        .output-box { background: #121212; border: 1px solid #e07a5f; padding: 15px; border-radius: 4px; overflow-x: auto; margin-top: 15px; }
    </style>
</head>
<body>

    <div id="lock-screen" class="container">
        <h1>Control Panel Access</h1>
        <div class="form-group">
            <label for="password-input">Enter Master Password:</label>
            <input type="password" id="password-input" placeholder="••••••••••••">
        </div>
        <button class="btn" onclick="verifyAccess()">Unlock Panel</button>
        <p id="error-msg" style="color: #ff6b6b; text-align: center; margin-top: 15px;"></p>
    </div>

    <div id="admin-dashboard" class="container hidden">
        <h1>Annie Rock Content Editor</h1>
        <p style="color: #a0a0a0; text-align: center;">Select a section block below to modify its content layout.</p>
        
        <div class="box-selector">
            <div class="box-option" id="box-mgmt" onclick="selectSection('mgmt')">
                <h3>Artist Management</h3>
            </div>
            <div class="box-option" id="box-studios" onclick="selectSection('studios')">
                <h3>Recording Studios Network</h3>
            </div>
        </div>

        <div id="editor-form" class="hidden">
            <div class="form-group">
                <label id="content-label" for="text-editor">Edit Content Layout (HTML allowed):</label>
                <textarea id="text-editor"></textarea>
            </div>
            <button class="btn" onclick="generateCode()">Generate Updated Webpage Code</button>
        </div>

        <div id="output-section" class="hidden" style="margin-top: 30px; border-top: 1px solid #333; padding-top: 20px;">
            <label>Success! Copy the entire code block below, go to GitHub, open your index.html, click edit, replace everything with this code, and save:</label>
            <textarea id="code-output" style="height: 300px;" readonly onclick="this.select()"></textarea>
        </div>
    </div>

    <script>
        // Scrambled version of "AnniRock2026!" using SHA-256 to prevent open disclosure
        const secureKey = "cbe27efdf052cf0fdf5eb72ca1265882b09c8dfb200b21697274092bbf0bc404";

        async function verifyAccess() {
            const input = document.getElementById("password-input").value;
            const msg = document.getElementById("error-msg");
            
            // Hash the user input to match against our key securely
            const encoder = new TextEncoder();
            const data = encoder.encode(input);
            const hashBuffer = await crypto.subtle.digest('SHA-256', data);
            const hashArray = Array.from(new Uint8Array(hashBuffer));
            const hashedInput = hashArray.map(b => b.toString(16).padStart(2, '0')).join('');

            if (hashedInput === secureKey) {
                document.getElementById("lock-screen").classList.add("hidden");
                document.getElementById("admin-dashboard").classList.remove("hidden");
            } else {
                msg.innerText = "Invalid Master Password. Access Denied.";
            }
        }

        let currentSection = '';
        
        // Baseline default structures to quickly populate the text field if empty
        const defaults = {
            mgmt: `            <div class="card">\n                <h2>Artist Management</h2>\n                <p>Protecting the vision while navigating the landscape. We help dedicated independent artists manage releases, structure publishing, and build sustainable careers.</p>\n            </div>`,
            studios: `        <div class="studios-section">\n            <h2>Recommended Recording Network</h2>\n            <div class="studio-list">\n                <div class="studio-item">\n                    <div class="studio-info">\n                        <h3>Studio Name One</h3>\n                        <p>Location City, ST — Premier tracking, mixing suite, and classic analog setups.</p>\n                    </div>\n                    <a href="#" class="studio-link" target="_blank">View Studio</a>\n                </div>\n            </div>\n        </div>`
        };

        function selectSection(section) {
            currentSection = section;
            document.querySelectorAll('.box-option').forEach(el => el.classList.remove('active'));
            document.getElementById('editor-form').classList.remove('hidden');
            
            if (section === 'mgmt') {
                document.getElementById('box-mgmt').classList.add('active');
                document.getElementById('content-label').innerText = "Edit Artist Management Box Code:";
                document.getElementById('text-editor').value = defaults.mgmt;
            } else if (section === 'studios') {
                document.getElementById('box-studios').classList.add('active');
                document.getElementById('content-label').innerText = "Edit Recording Studios Network Code Grid:";
                document.getElementById('text-editor').value = defaults.studios;
            }
        }

        function generateCode() {
            const userEdit = document.getElementById('text-editor').value;
            let finalMgmt = defaults.mgmt;
            let finalStudios = defaults.studios;

            if (currentSection === 'mgmt') finalMgmt = userEdit;
            if (currentSection === 'studios') finalStudios = userEdit;

            // Merges the edits dynamically back into your core index.html architecture
            const dynamicTemplate = `<!DOCTYPE html>\n<html lang="en">\n<head>\n    <meta charset="UTF-8">\n    <meta name="viewport" content="width=device-width, initial-scale=1.0">\n    <title>Annie Rock Studios | Management & A&R</title>\n    <style>\n        :root {\n            --bg-color: #121212;\n            --card-bg: #1e1e1e;\n            --accent-color: #e07a5f;\n            --text-main: #f4f4f4;\n            --text-muted: #a0a0a0;\n        }\n        body {\n            background-color: var(--bg-color);\n            color: var(--text-main);\n            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;\n            margin: 0;\n            padding: 0;\n            line-height: 1.6;\n        }\n        header {\n            max-width: 800px;\n            margin: 0 auto;\n            padding: 40px 20px 40px 20px;\n            text-align: center;\n        }\n        header img {\n            display: block;\n            margin: 0 auto 20px auto;\n            max-width: 500px;\n            width: 100%;\n            height: auto;\n            border-radius: 4px;\n        }\n        header h1 {\n            font-size: 2.5rem;\n            margin-bottom: 10px;\n            letter-spacing: -0.5px;\n        }\n        header p {\n            color: var(--text-muted);\n            font-size: 1.1rem;\n            max-width: 600px;\n            margin: 0 auto;\n        }\n        .main-container {\n            max-width: 800px;\n            margin: 0 auto;\n            padding: 0 20px 60px 20px;\n        }\n        .grid {\n            display: grid;\n            grid-template-columns: 1fr 1fr;\n            gap: 20px;\n            margin-bottom: 40px;\n        }\n        @media (max-width: 600px) {\n            .grid { grid-template-columns: 1fr; }\n        }\n        .card {\n            background-color: var(--card-bg);\n            padding: 30px;\n            border-radius: 8px;\n            border: 1px solid #2a2a2a;\n        }\n        .card h2 {\n            margin-top: 0;\n            color: var(--accent-color);\n            font-size: 1.4rem;\n        }\n        .studios-section {\n            margin-top: 40px;\n            border-top: 1px solid #2a2a2a;\n            padding-top: 40px;\n            text-align: left;\n        }\n        .studios-section h2 {\n            font-size: 1.8rem;\n            margin-bottom: 20px;\n            text-align: center;\n        }\n        .studio-list {\n            display: flex;\n            flex-direction: column;\n            gap: 15px;\n        }\n        .studio-item {\n            background-color: var(--card-bg);\n            padding: 20px;\n            border-radius: 8px;\n            border: 1px solid #2a2a2a;\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n        }\n        @media (max-width: 600px) {\n            .studio-item { flex-direction: column; align-items: flex-start; gap: 10px; }\n        }\n        .studio-info h3 {\n            margin: 0 0 5px 0;\n            font-size: 1.2rem;\n        }\n        .studio-info p {\n            margin: 0;\n            color: var(--text-muted);\n            font-size: 0.95rem;\n        }\n        .studio-link {\n            color: var(--accent-color);\n            text-decoration: none;\n            font-weight: bold;\n            font-size: 0.9rem;\n            border: 1px solid var(--accent-color);\n            padding: 6px 12px;\n            border-radius: 4px;\n        }\n        .studio-link:hover {\n            background-color: var(--accent-color);\n            color: var(--bg-color);\n        }\n        .blog-section {\n            margin-top: 50px;\n            border-top: 1px solid #2a2a2a;\n            padding-top: 40px;\n        }\n        .blog-section h2 {\n            font-size: 1.8rem;\n            margin-bottom: 30px;\n            text-align: center;\n        }\n        .blog-post {\n            background-color: var(--card-bg);\n            padding: 25px;\n            border-radius: 8px;\n            margin-bottom: 20px;\n            border: 1px solid #2a2a2a;\n            text-align: left;\n        }            .blog-post .meta {\n            font-size: 0.85rem;\n            color: var(--accent-color);\n            margin-bottom: 10px;\n            text-transform: uppercase;\n            letter-spacing: 1px;\n        }\n        .blog-post h3 {\n            margin: 0 0 10px 0;\n            font-size: 1.3rem;\n        }\n        .blog-post p {\n            color: var(--text-muted);\n            margin: 0;\n        }\n        .btn {\n            display: inline-block;\n            background-color: var(--accent-color);\n            color: var(--bg-color);\n            text-decoration: none;\n            padding: 10px 20px;\n            border-radius: 4px;\n            font-weight: bold;\n            margin-top: 15px;\n            transition: background 0.2s;\n        }\n        .btn:hover { background-color: #f29075; }\n    </style>\n</head>\n<body>\n\n    <header>\n        <img src="IMG_2003.jpeg" alt="Annie Rock Studios Cabin Illustration">\n        <h1>Annie Rock Studios</h1>\n        <p>A warm, grounded space for independent talent. We specialize in intentional artist management, discovery, and transparent industry insights.</p>\n    </header>\n\n    <div class="main-container">\n        <div class="grid">\n${finalMgmt}\n            <div class="card">\n                <h2>A&R & Submissions</h2>\n                <p>Looking for your next development partner? We are constantly filtering for fresh sounds, distinct viewpoints, and authentic storytelling.</p>\n                <a href="mailto:submissions@annierock.com" class="btn">Submit Demo</a>\n            </div>\n        </div>\n\n${finalStudios}\n\n        <div class="blog-section">\n            <h2>The Annie Rock Blog</h2>\n            <div class="blog-post">\n                <div class="meta">July 2026 &bull; Industry Insight</div>\n                <h3>Understanding Your Publishing Catalog</h3>\n                <p>Before you pitch your next track for sync licensing, ensure your registry registrations are bulletproof. Here is a baseline checklist for handling your own performance rights metrics...</p>\n            </div>\n            <div class="blog-post">\n                <div class="meta">June 2026 &bull; Studio Notes</div>\n                <h3>The Power of the B-Side Atmosphere</h3>\n                <p>Polished commercial singles have their place, but the raw B-side track is often where an artist reveals their actual foundational style. Embracing the unpolished moments creates true fans...</p>\n            </div>\n        </div>\n    </div>\n\n</body>\n</html>`;

            document.getElementById('output-section').classList.remove('hidden');
            document.getElementById('code-output').value = dynamicTemplate;
        }
    </script>
</body>
</html>
